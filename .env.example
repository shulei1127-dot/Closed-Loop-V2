APP_NAME=closed_loop_v2
APP_ENV=development
APP_DEBUG=false
API_PREFIX=/api
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/closed_loop_v2
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_ENABLED=true
LOG_LEVEL=INFO
DINGTALK_DEFAULT_HEADERS_JSON={}
DINGTALK_DEFAULT_COOKIES_JSON={}
DINGTALK_AUTH_TOKEN=
DINGTALK_REQUEST_TIMEOUT_SECONDS=15
DINGTALK_VERIFY_SSL=true
# PTS Web session settings.
# visit real execution uses PTS_COOKIE_HEADER when opening the PTS delivery link.
# proactive real execution currently does not read PTS Web session cookies directly.
PTS_BASE_URL=https://pts.chaitin.net
PTS_COOKIE_HEADER=
PTS_VERIFY_SSL=true

# Global execution gate.
ENABLE_REAL_EXECUTION=false

# Visit real execution.
VISIT_REAL_EXECUTION_ENABLED=false
VISIT_REAL_BASE_URL=
VISIT_REAL_TOKEN=
VISIT_REAL_TOKEN_HEADER=X-Visit-Token
VISIT_REAL_CREATE_ENDPOINT=/visit-work-orders
VISIT_REAL_ASSIGN_ENDPOINT_TEMPLATE=/visit-work-orders/{delivery_id}/assign-owner
VISIT_REAL_MARK_TARGET_ENDPOINT_TEMPLATE=/visit-work-orders/{delivery_id}/mark-target
VISIT_REAL_FILL_FEEDBACK_ENDPOINT_TEMPLATE=/visit-work-orders/{delivery_id}/fill-feedback
VISIT_REAL_COMPLETE_ENDPOINT_TEMPLATE=/visit-work-orders/{delivery_id}/complete
VISIT_REAL_FINAL_LINK_PATH=data.final_link
VISIT_REAL_TIMEOUT_SECONDS=15
VISIT_REAL_VERIFY_SSL=true

# Inspection real execution.
INSPECTION_REAL_EXECUTION_ENABLED=false
INSPECTION_REAL_BASE_URL=
INSPECTION_REAL_TOKEN=
INSPECTION_REAL_TOKEN_HEADER=X-Inspection-Token
INSPECTION_REAL_ASSIGN_ENDPOINT_TEMPLATE=/inspection-work-orders/{work_order_id}/assign-owner
INSPECTION_REAL_ADD_MEMBER_ENDPOINT_TEMPLATE=/inspection-work-orders/{work_order_id}/add-member
INSPECTION_REAL_UPLOAD_ENDPOINT_TEMPLATE=/inspection-work-orders/{work_order_id}/upload-reports
INSPECTION_REAL_COMPLETE_ENDPOINT_TEMPLATE=/inspection-work-orders/{work_order_id}/complete
INSPECTION_REAL_FINAL_LINK_PATH=data.final_link
INSPECTION_REAL_TIMEOUT_SECONDS=15
INSPECTION_REAL_VERIFY_SSL=true

# Proactive real execution.
PROACTIVE_REAL_EXECUTION_ENABLED=false
PROACTIVE_REAL_BASE_URL=
PROACTIVE_REAL_TOKEN=
PROACTIVE_REAL_TOKEN_HEADER=X-Proactive-Token
PROACTIVE_REAL_CREATE_ENDPOINT=/proactive-work-orders
PROACTIVE_REAL_ASSIGN_ENDPOINT_TEMPLATE=/proactive-work-orders/{work_order_id}/assign-owner
PROACTIVE_REAL_FEEDBACK_ENDPOINT_TEMPLATE=/proactive-work-orders/{work_order_id}/fill-feedback
PROACTIVE_REAL_FINAL_LINK_PATH=data.final_link
PROACTIVE_REAL_TIMEOUT_SECONDS=15
PROACTIVE_REAL_VERIFY_SSL=true

# Inspection report root.
INSPECTION_REPORT_ROOT=/Users/shulei/Downloads/巡检报告集合-已审核

# Scheduler / retry.
SYNC_RETRY_MAX_ATTEMPTS=2
EXECUTE_RETRY_MAX_ATTEMPTS=2
